APP_SECRET_KEY=dev-only-change-me
DATABASE_URL=postgresql+psycopg://postgres:123456@127.0.0.1:5433/psychology_agent

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_KNOWLEDGE_MODEL=deepseek-v4-pro
DEEPSEEK_TIMEOUT_SECONDS=20
RISK_SEMANTIC_LLM_ENABLED=0
RISK_SEMANTIC_LLM_TIMEOUT_SECONDS=1.5
CHAT_TURN_TIMEOUT_SECONDS=120
RAG_RETRIEVAL_TIMEOUT_SECONDS=60
KNOWLEDGE_WARM_INDEX_ON_STARTUP=0
COUNSELING_RAG_ENABLED=0

MILVUS_ENABLED=0
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION_PREFIX=psych_agent

EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024
LOCAL_EMBEDDING_DEVICE=auto
LOCAL_EMBEDDING_BATCH_SIZE=8
LOCAL_EMBEDDING_MAX_LENGTH=1024
LOCAL_EMBEDDING_USE_FP16=auto
LOCAL_EMBEDDING_CACHE_DIR=
LOCAL_EMBEDDING_WARM_ON_STARTUP=0
LOCAL_EMBEDDING_USE_WORKER=auto
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_QUERY_CACHE_SIZE=128
